<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysClassMapper">

    <resultMap type="com.ruoyi.common.core.domain.entity.SysClass" id="SysClassResult">
        <id     property="id"         column="id"          />
        <result property="className"  column="class_name"  />
        <result property="gradeId"    column="grade_id"    />
        <result property="delFlag"    column="del_flag"   />
        <result property="createTime" column="create_time" />
        <result property="gradeName"  column="grade_name"  />
    </resultMap>

    <sql id="selectClassVo">
        select c.id, c.class_name, c.grade_id, c.del_flag, c.create_time, g.grade_name
        from sys_class c
        left join sys_grade g on c.grade_id = g.id
    </sql>

    <select id="selectClassList" parameterType="com.ruoyi.common.core.domain.entity.SysClass" resultMap="SysClassResult">
        <include refid="selectClassVo"/>
        where c.del_flag = '0'
        <if test="gradeId != null">
            AND c.grade_id = #{gradeId}
        </if>
        <if test="className != null and className != ''">
            AND c.class_name like concat('%', #{className}, '%')
        </if>
        order by g.sort asc, c.id asc
    </select>

    <select id="selectClassById" parameterType="Long" resultMap="SysClassResult">
        <include refid="selectClassVo"/>
        where c.id = #{id} and c.del_flag = '0'
    </select>

    <select id="countByGradeId" parameterType="Long" resultType="int">
        select count(1) from sys_class where grade_id = #{gradeId} and del_flag = '0'
    </select>

    <select id="checkClassNameUnique" resultMap="SysClassResult">
        <include refid="selectClassVo"/>
        where c.class_name = #{className} and c.grade_id = #{gradeId} and c.del_flag = '0' limit 1
    </select>

    <select id="selectByGradeNameAndClassName" resultMap="SysClassResult">
        <include refid="selectClassVo"/>
        where g.grade_name = #{gradeName} and c.class_name = #{className} and c.del_flag = '0' and g.del_flag = '0' limit 1
    </select>

    <insert id="insertClass" parameterType="com.ruoyi.common.core.domain.entity.SysClass" useGeneratedKeys="true" keyProperty="id">
        insert into sys_class(class_name, grade_id, create_time)
        values (#{className}, #{gradeId}, CURRENT_TIMESTAMP)
    </insert>

    <update id="updateClass" parameterType="com.ruoyi.common.core.domain.entity.SysClass">
        update sys_class
        <set>
            <if test="className != null and className != ''">class_name = #{className},</if>
            <if test="gradeId != null">grade_id = #{gradeId},</if>
        </set>
        where id = #{id}
    </update>

    <update id="deleteClassById" parameterType="Long">
        update sys_class set del_flag = '2' where id = #{id}
    </update>
</mapper>
