# 东陆高中选课系统 - 前端镜像 (Nginx)
# 构建上下文: 项目根目录（需先执行 build-for-deploy 生成 deploy/）

FROM nginx:alpine

RUN rm -rf /usr/share/nginx/html/*

COPY deploy/frontend-admin/dist/ /usr/share/nginx/html/
COPY deploy/frontend-student/h5/ /usr/share/nginx/html/h5/
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
