# Docker 部署环境变量示例
# 复制为 .env 后修改，deploy-docker.sh 会自动加载

# PostgreSQL（宿主机或 Docker 容器，端口需映射到宿主机 5432）
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_DB=ry_vue
POSTGRES_USER=postgres
PG_PASSWORD=your_password

# 数据库初始化用（init-db.sh）
# PostgreSQL 在 Docker 时，Linux 下可设 DB_HOST=172.17.0.1
DB_HOST=host.docker.internal
DB_PASS=your_password

# Redis（宿主机或 Docker 容器）
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# 前端端口（默认 9090）
FRONTEND_PORT=9090
